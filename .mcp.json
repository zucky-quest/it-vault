{
  "mcpServers": {
    "github": {
      "type": "stdio",
      "command": "npx",
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ]
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena-mcp-server",
        "--context",
        "ide-assistant"
      ]
    },
    "obsidian": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-obsidian",
        "${env:OBSIDIAN_VAULT_PATH}"
      ]
    }
  }
}
